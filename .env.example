# ==============================================================================
# NextStepCV - AI-Powered Curriculum Vitae Builder
# Tested on: i5-8250U | 32GB RAM | Ubuntu 24.04
# ==============================================================================

# --- APP CONFIGURATION ---
# Environment: development, production
NODE_ENV=production
ENABLE_AI_FEATURES=1 # Set to 1 to enable AI features, 0 to disable
LOG_LEVEL=debug
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- AUTHENTICATION ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace_this_with_a_secure_hex_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- OLLAMA AI (LOCAL) ---
AI_MODEL_LOCAL=qwen2.5:3b
OLLAMA_BASE_URL=http://ollama-service:11434
OLLAMA_HOST=ollama-service
OLLAMA_MAX_CPU=4.0
OLLAMA_MAX_RAM=8g
OLLAMA_NUM_THREAD=4
OLLAMA_NUM_PARALLEL=1
AI_REQUEST_TIMEOUT=120
AI_DETAILED_MODE=true

# --- DATABASE (POSTGRES) ---
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=nextstepcv_db
DATABASE_URL=postgresql://your_db_user:your_secure_password@db:5432/nextstepcv_db

# --- STORAGE (MINIO / S3) ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=your_secure_password
MINIO_ENDPOINT=http://minio-service:9000
MINIO_BUCKET_NAME=curriculums
MINIO_PUBLIC_URL=http://localhost:9000
# Note: Set to 'true' if using HTTPS for MinIO, otherwise 'false'
MINIO_USE_SSL=false

# --- UPLOAD LIMITS ---
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=pdf,docx,jpg,png

MAX_ASOCIATED_CV=5

# --- NETWORK PORTS ---
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001