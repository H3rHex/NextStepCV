{
  "name": "NextStepCV Dev",
  "dockerComposeFile": [
    "docker-compose.yml"
  ],
  "service": "dev",
  "overrideCommand": true,
  "workspaceFolder": "/workspaces/NextStepCV",
  "postCreateCommand": "bash -lc 'bash /workspaces/NextStepCV/.devcontainer/post-create.sh'",
  "forwardPorts": [8000, 5173,9001, 5432],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss",
        "redhat.vscode-yaml",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
