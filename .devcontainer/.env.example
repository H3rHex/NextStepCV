# --- APP CONFIGURATION ---
NODE_ENV=development
ENABLE_AI_FEATURES=1
LOG_LEVEL=debug
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- AUTHENTICATION ---
JWT_SECRET_KEY=123456
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- OLLAMA AI (LOCAL) ---
AI_MODEL_LOCAL=qwen2.5:3b
OLLAMA_BASE_URL=http://ollama-service:11434
OLLAMA_HOST=ollama-service
OLLAMA_MAX_CPU=4.0
OLLAMA_MAX_RAM=8g
OLLAMA_NUM_THREAD=4
OLLAMA_NUM_PARALLEL=1
AI_REQUEST_TIMEOUT=120
AI_DETAILED_MODE=true

# --- DATABASE (POSTGRES) ---
POSTGRES_USER=root
POSTGRES_PASSWORD=123456
POSTGRES_DB=nextstepcv_db
DATABASE_URL=postgresql://root:123456@db:5432/nextstepcv_db

# --- STORAGE (MINIO / S3) ---
MINIO_ROOT_USER=root
MINIO_ROOT_PASSWORD=12345678
MINIO_ENDPOINT=http://minio-service:9000
MINIO_BUCKET_NAME=curriculums
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_USE_SSL=false

# --- UPLOAD LIMITS ---
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=pdf,docx,jpg,png

# --- NETWORK PORTS ---
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5435
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
