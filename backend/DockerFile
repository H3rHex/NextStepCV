FROM python:3.11-slim

# Install system dependencies for WeasyPrint, PDF processing and DB
RUN apt-get update && apt-get install -y \
    python3-cffi python3-brotli libpango-1.0-0 libharfbuzz0b \
    libpangoft2-1.0-0 libpangocairo-1.0-0 libpq-dev \
    && apt-get clean

# Install uv and python dependencies
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
WORKDIR /app
COPY requirements.txt .
RUN uv pip install --system -r requirements.txt

COPY . .

# Execute with Uvicorn (4 workers for production)
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "4"]